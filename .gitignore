# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local credential notes, never commit
*.local.md

# vercel
.vercel

# 外部 API 的本地快取 fallback 檔案（例如天氣），內容是執行期抓到的資料，不是原始碼
data/.cache/

# typescript
*.tsbuildinfo
next-env.d.ts
